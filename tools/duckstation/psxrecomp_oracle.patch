+// ---------------------------------------------------------------------------
+// Public API
+// ---------------------------------------------------------------------------
+
+bool PSXRecompDebug::Initialize(u16 port)
+{
+  Error error;
+  Assert(!s_listen_socket);
+
+  const std::optional<SocketAddress> address =
+    SocketAddress::Parse(SocketAddress::Type::IPv4, "127.0.0.1", port, &error);
+  if (!address.has_value())
+  {
+    ERROR_LOG("Failed to parse address: {}", error.GetDescription());
+    return false;
+  }
+
+  SocketMultiplexer* multiplexer = System::GetSocketMultiplexer();
+  if (!multiplexer) return false;
+
+  s_listen_socket = multiplexer->CreateListenSocket<ClientSocket>(address.value(), &error);
+  if (!s_listen_socket)
+  {
+    ERROR_LOG("Failed to create listen socket: {}", error.GetDescription());
+    System::ReleaseSocketMultiplexer();
+    return false;
+  }
+
+  s_frame_counter = 0;
+  s_paused = false;
+  s_step_frames = 0;
+  s_run_to_frame = 0;
+  s_history_count = 0;
+  std::memset(s_watchpoints, 0, sizeof(s_watchpoints));
+  std::memset(s_pc_breaks, 0, sizeof(s_pc_breaks));
+  s_pc_hit_last.valid = false;
+  std::memset(s_history, 0, sizeof(s_history));
+
+  INFO_LOG("PSXRecomp debug server listening on 127.0.0.1:{}", port);
+  return true;
+}
+
+bool PSXRecompDebug::HasAnyClients() { return !s_clients.empty(); }
+
+void PSXRecompDebug::Shutdown()
+{
+  if (!s_listen_socket) return;
+  INFO_LOG("Shutting down PSXRecomp debug server ({} clients)", s_clients.size());
+  s_clients.clear();
+  s_listen_socket.reset();
+  System::ReleaseSocketMultiplexer();
+}
+
+void PSXRecompDebug::OnFrameDone()
+{
+  s_frame_counter++;
+
+  // ---- Record frame into ring buffer ----
+  u32 idx = s_frame_counter % FRAME_HISTORY_CAP;
+  FrameRecord& r = s_history[idx];
+  r.frame_number = s_frame_counter;
+
+  // CPU
+  for (int i = 0; i < 32; i++)
+    r.gpr[i] = CPU::g_state.regs.r[i];
+  r.pc = CPU::g_state.pc;
+  r.hi = CPU::g_state.regs.hi;
+  r.lo = CPU::g_state.regs.lo;
+
+  // GPU
+  r.display_vram_left = g_gpu.GetDisplayVRAMLeft();
+  r.display_vram_top = g_gpu.GetDisplayVRAMTop();
+  r.display_vram_width = g_gpu.GetDisplayVRAMWidth();
+  r.display_vram_height = g_gpu.GetDisplayVRAMHeight();
+  r.display_disable = g_gpu.IsDisplayDisabled() ? 1 : 0;
+  r.interlaced = g_gpu.IsInterlacedDisplayEnabled() ? 1 : 0;
+  r.pal_mode = g_gpu.IsInPALMode() ? 1 : 0;
+  r._gpu_pad = 0;
+
+  // Pad
+  Controller* ctrl = System::GetController(0);
+  r.pad1_buttons = ctrl ? static_cast<u16>(ctrl->GetButtonStateBits()) : 0xFFFF;
+
+  r._reserved = 0;
+
+  // RAM snapshots
+  for (int si = 0; si < RAM_SNAPSHOT_REGIONS; si++)
+  {
+    r.snapshot_addr[si] = s_snapshot_addrs[si];
+    if (s_snapshot_addrs[si] != 0 && s_snapshot_addrs[si] + RAM_SNAPSHOT_SIZE <= Bus::g_ram_size)
+      std::memcpy(r.snapshot_data[si], Bus::g_ram + s_snapshot_addrs[si], RAM_SNAPSHOT_SIZE);
+    else
+      std::memset(r.snapshot_data[si], 0, RAM_SNAPSHOT_SIZE);
+  }
+
+  s_history_count = static_cast<u64>(s_frame_counter) + 1;
+
+  // ---- Input override ----
+  if (s_input_override >= 0)
+  {
+    Controller* pad = System::GetController(0);
+    if (pad)
+    {
+      u16 mask = static_cast<u16>(s_input_override);
+      for (u32 bit = 0; bit < 16; bit++)
+      {
+        // PS1 bitmask: 0 = pressed, 1 = released
+        float value = ((mask >> bit) & 1) == 0 ? 1.0f : 0.0f;
+        pad->SetBindState(bit, value);
+      }
+    }
+  }
+
+  // ---- Watchpoints ----
+  for (int i = 0; i < MAX_WATCHPOINTS; i++)
+  {
+    if (!s_watchpoints[i].active || s_watchpoints[i].addr >= Bus::g_ram_size)
+      continue;
+    u8 cur = Bus::g_ram[s_watchpoints[i].addr];
+    if (cur != s_watchpoints[i].prev_val)
+    {
+      BroadcastJSON(fmt::format(
+        R"({{"event":"watchpoint","addr":"0x{:08X}","old":"0x{:02X}","new":"0x{:02X}","frame":{}}})",
+        s_watchpoints[i].addr | 0x80000000u, s_watchpoints[i].prev_val, cur, s_frame_counter));
+      s_watchpoints[i].prev_val = cur;
+    }
+  }
+
+  // ---- Step mode ----
+  if (s_step_frames > 0)
+  {
+    s_step_frames--;
+    if (s_step_frames == 0)
+    {
+      s_paused = true;
+      System::PauseSystem(true);
+      BroadcastJSON(fmt::format(R"({{"event":"step_done","frame":{}}})", s_frame_counter));
+    }
+  }
+
+  // ---- Run-to-frame mode ----
+  if (s_run_to_frame > 0 && s_frame_counter >= s_run_to_frame)
+  {
+    s_run_to_frame = 0;
+    s_paused = true;
+    System::PauseSystem(true);
+    BroadcastJSON(fmt::format(R"({{"event":"run_to_done","frame":{}}})", s_frame_counter));
+  }
+}
